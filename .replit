modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Oranje Dev Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Oranje Backend (API only)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Oranje Frontend (Vite)"

[[workflows.workflow]]
name = "Oranje Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/oranje && PORT=3000 npm run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "Oranje Backend (API only)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/oranje && PORT=3001 npm run dev:server"
waitForPort = 3001

[[workflows.workflow]]
name = "Oranje Frontend (Vite)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/oranje && PORT=3002 BACKEND_PORT=3001 npm run dev:client"
waitForPort = 3002

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

