# =============================================================================
# ORANJE - Environment Variables
# =============================================================================

# Database (MySQL/MariaDB)
DATABASE_URL=mysql://user:password@host:port/database

# Authentication
JWT_SECRET=your-jwt-secret-here
VITE_APP_ID=oranje-standalone

# CORS (comma-separated frontend origins for split deploys)
CORS_ORIGINS=https://oranje-vercel.vercel.app,https://oranjeapp.com.br

# Owner
OWNER_OPEN_ID=admin-owner

# Admin key for CMS
ADMIN_KEY=your-admin-key

# Analytics (optional)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Frontend-only: API URL (set when frontend is deployed separately from backend)
# VITE_API_URL=https://your-railway-backend.up.railway.app
